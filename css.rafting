contact-info, .employee-profiles, .contact-form {
  margin: 2rem 0;
}

.employee-profiles img {
  width: 200px;
  border-radius: 8px;
  margin: 1rem;
}

.contact-form label, .contact-form input, .contact-form textarea, .contact-form button {
  display: block;
  margin: 0.5rem 0;
}

.contact-form button {
  background-color: #0077cc;
  color: white;
  padding: 0.75rem 1.5rem;
  border: none;
  border-radius: 5px;
  cursor: pointer;
}

.contact-form button:hover {
  background-color: #005fa3;
}

